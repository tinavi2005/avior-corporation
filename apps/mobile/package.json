{
  "name": "@vale-integrador/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "build": "expo export",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "test:e2e": "echo 'no e2e tests yet'",
    "clean": "rm -rf .expo dist coverage"
  },
  "dependencies": {
    "@insforge/sdk": "^1.3.0",
    "expo": "^51.0.0",
    "expo-router": "^3.4.0",
    "expo-status-bar": "~2.0.0",
    "lucide-react-native": "^0.312.0",
    "nativewind": "^4.0.0",
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "react-native-gesture-handler": "^3.0.1",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "~3.31.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.4.0",
    "@types/react": "^18.2.0",
    "@vitest/coverage-v8": "^1.3.0",
    "eslint": "^9.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0"
  }
}
