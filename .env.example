# ─────────────────────────────────────────────────────────
#  Avior SRL — Variables de entorno
#  Copia este archivo a .env y rellena los valores
# ─────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=avior
POSTGRES_PASSWORD=avior_pass_cambiar_en_produccion
POSTGRES_DB=avior_db

# ── Insforge (auth service) ───────────────────────────────
# Obtén estas claves en tu dashboard de Insforge
INSFORGE_URL=https://z334twfi.us-east.insforge.app
INSFORGE_API_KEY=ik_your_service_api_key

# ── Web (Next.js) ─────────────────────────────────────────
NEXT_PUBLIC_INSFORGE_URL=https://z334twfi.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_insforge_anon_jwt
NEXT_PUBLIC_API_URL=http://localhost:5555
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── API ───────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_una_cadena_aleatoria_larga
